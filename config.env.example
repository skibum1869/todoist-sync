TODOIST_API_KEY="YOUR_API_KEY_HERE"

# Name of the dedicated list (Reminders) / project (Todoist) to sync.
# Created automatically on both sides if it doesn't already exist.
SYNC_LIST_NAME="Siri Sync"

# Which side wins when a completion, due date, title, or notes change on
# both sides differently between two syncs. Must be "reminders" or
# "todoist".
SYNC_CONFLICT_WINNER="reminders"

# Once a pair has been completed on both sides for this many days, it's
# moved out of active reconciliation and into the archive (still matched
# by id if reactivated, but no longer polled every run).
SYNC_ARCHIVE_AFTER_DAYS="180"

# Once a pair's reminder and/or task has been confirmed missing (deleted)
# for this many consecutive sync runs, the pair is dropped from state.json
# entirely rather than being polled forever. A check count, not elapsed
# time, so it demands that many independent confirmations regardless of
# gaps between runs (e.g. the Mac sleeping) — at the default 15-minute
# sync interval, 4 checks is about 1 hour.
SYNC_PRUNE_MISSING_AFTER_CHECKS="4"
