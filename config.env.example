TODOIST_API_KEY="YOUR_API_KEY_HERE"

# Name of the dedicated list (Reminders) / project (Todoist) to sync.
# Created automatically on both sides if it doesn't already exist.
SYNC_LIST_NAME="Siri Sync"

# Which side wins when a completion, due date, title, or notes change on
# both sides differently between two syncs. Must be "reminders" or
# "todoist".
SYNC_CONFLICT_WINNER="reminders"
